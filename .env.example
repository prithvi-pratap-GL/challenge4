# VentureMind AI - Environment Configuration
# Copy this to .env and fill in your API keys

# ===== PERSON 2: RESEARCH INTELLIGENCE =====
# Tavily Search API - Web search and intelligence
TAVILY_API_KEY=tvly_xxx

# Firecrawl API - Website extraction
FIRECRAWL_API_KEY=fc_xxx

# Crunchbase API - Company and funding data
CRUNCHBASE_API_KEY=cb_xxx

# LinkedIn API - Founder profiles
LINKEDIN_API_KEY=li_xxx

# ===== PERSON 3: KNOWLEDGE & EMBEDDINGS =====
# Qdrant Vector Database
QDRANT_URL=https://xxx.qdrant.io:6333
QDRANT_API_KEY=qdrant_xxx

# Embedding Model
EMBEDDING_MODEL=text-embedding-3-small

# ===== PERSON 5: PLATFORM & LLM =====
# OpenAI Configuration
MODEL_NAME=gpt-4-turbo
BASE_URL=https://api.openai.com/v1
API_KEY=sk_xxx
TEMPERATURE=0.7

# Or use Azure OpenAI
# BASE_URL=https://{resource}.openai.azure.com/
# API_VERSION=2024-02-15-preview
# DEPLOYMENT_NAME=gpt-4-deployment

# Or use local models
# MODEL_NAME=ollama-llama2
# BASE_URL=http://localhost:11434/v1
# API_KEY=not-needed

# ===== POSTGRES DATABASE =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=venturemind
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=venturemind_ai

# ===== ENVIRONMENT =====
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
